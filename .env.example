# Database
DATABASE_URL="postgresql://doccollector:password@localhost:5432/doccollector_db"

# App
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"

# Cifratura AES-256 — genera con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="<64_char_hex>"
ENCRYPTION_KEY_ID="key-v1"

# SMTP
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="apikey"
SMTP_PASS="<api_key>"
SMTP_DEFAULT_FROM="DocCollector+ <noreply@doccollector.it>"